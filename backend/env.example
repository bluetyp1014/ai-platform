# Copy to .env.docker for Docker, or .env for local runs.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_platform
MONGODB_URL=mongodb://admin:password@mongodb:27017/?authSource=admin
MONGODB_DB=ai_platform
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:12b
